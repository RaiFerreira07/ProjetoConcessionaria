@model ProjetoConcessionaria.ViewModels.HomeDashboardViewModel

@{
    ViewData["Title"] = "Início";
}

@await Html.PartialAsync("_CardsResumo", Model.CardsResumo)

<div class="container my-4 flex-grow-1">
    <main role="main" class="pb-3">
        <h4 class="mb-3">Últimas Vendas</h4>
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Data</th>
                    <th>Cliente</th>
                    <th>Veículo</th>
                    <th>Valor</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var venda in Model.UltimasVendas)
                {
                    <tr>
                        <td>@venda.DataVenda.ToString("dd/MM/yyyy")</td>
                        <td>@venda.Cliente.Nome</td>
                        <td>@venda.Veiculo.Marca @venda.Veiculo.Modelo</td>
                        <td>R$ @venda.ValorFinal.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </main>
</div>
